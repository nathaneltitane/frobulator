# assess ///////////////////////////////////////////////////////////////////////

# use to assess 'superuser' status and prompt for priviledged execution
# useful for in-script dependency assessment and installation

# usage:      frobulator.assess "[package]" | "[array]"

frobulator.assess () {

	local status=0

	local command
	local reply
	local user_current

	if [[ "${#list[@]}" -gt 0 ]]
	then
		# ${1} - array

		list=("${@:1}")
	else
		command="${1}"

		list=()

		list+=("${command}")
	fi

	user_current="$(id -u -n)"

	if [ "${?}" -ne 0 ]
	then
		list=()

		return 1
	fi

	if [ "${user_current}" = "root" ]
	then
		frobulator.require "${list[@]}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		else
			frobulator.msg "Requirement(s) installed" "[ ${script} ]"
			echo

			frobulator.inf "Restart as '${USER}' to proceed" "[ '${script}' ]"
			echo
		fi
	else
		for command in "${list[@]}"
		do
			if [[ -z $(command -v "${command}") ]]
			then
				frobulator.err "Missing" "[ '${command}' ]"
				echo

				frobulator.wrn "Privilege escalation required to proceed" "[ '${script}' ]"
				echo

				frobulator.ask "Launch as 'root'?"

				read -r reply
				echo

				if [[ "${reply}" = [yY] ]] || [[ "${reply}" = [yY][eE][sS] ]]
				then
					frobulator.escalate

					if [ "${?}" -ne 0 ]
					then
						status=1
					fi
				else
					frobulator.wrn "Launch as 'root' to install requirement(s)" "[ '${script}' ]"
					echo

					status=1
				fi
			fi
		done
	fi

	# unset array

	list=()

	return "${status}"

}

# escalate /////////////////////////////////////////////////////////////////////

# use to provide priviledged command or script execution
# restarts process as 'superuser' once status is granted

# usage:      export self_arguments="${@}"
#             frobulator.escalate

frobulator.escalate () {

	local status=0

	local self="${0}"
	local user_current
	local self_arguments_list=()

	read -r -a self_arguments_list <<< "${self_arguments}"

	user_current="$(id -u -n)"

	if [ "${?}" -ne 0 ]
	then
		return 1
	fi

	if [ "${user_current}" = "root" ]
	then
		frobulator.fwd "Validating privilege escalation" "[ '${USER}' ]"
		echo

		if [ -n "${SUDO_USER}" ]
		then
			USER="${SUDO_USER}"
			HOME="/home/${SUDO_USER}"
		else
			USER="root"
			HOME="/root"
		fi
	else
		frobulator.wrn "Granting privilege escalation" "[ '${SUDO_USER:-${USER}}' ]"
		echo

		frobulator.fwd "Restarting" "[ '${self}' ]"
		echo

		frobulator.user

		if [[ -z $(command -v sudo) ]]
		then
			frobulator.require sudo

			if [ "${?}" -ne 0 ]
			then
				return 1
			fi
		fi

		# set superuser password prompt

		export SUDO_PROMPT="[${marker_spc}$(tput setaf 3)${USER}$(tput sgr 0)${marker_spc}]${marker_spc}>_${marker_spc}?${marker_spc}"

		# restart as superuser

		exec sudo "${SHELL}" "${self}" "${self_arguments_list[@]}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	fi

	return "${status}"

}

# archive //////////////////////////////////////////////////////////////////////

# use to archive content and for backup procedures

# "${directory}" defaults to "${PWD}" when omitted

# usage:      frobulator.archive "[archive]" "[type]" "[directory]"

frobulator.archive () {

	local status=0

	local file="${1}"
	local extension="${2}"
	local directory="${3:-${PWD}}"
	local archive
	local dependency

	if [ -z "${file}" ]
	then
		frobulator.err "No archive name specified"
		echo

		return 1
	fi

	if [ -z "${extension}" ]
	then
		frobulator.err "No archive type specified"
		echo

		return 1
	fi

	if [ ! -d "${directory}" ]
	then
		frobulator.err "Unavailable" "[ '${directory}' ]"
		echo

		return 1
	fi

	archive="${file}.${extension}"

	if [ "${extension}" = "tar.bz2" ] || \
	   [ "${extension}" = "tbz2"    ]
	then
		dependency="tar"

	elif [ "${extension}" = "tar.gz" ] || \
	     [ "${extension}" = "tgz"    ]
	then
		dependency="tar"

	elif [ "${extension}" = "tar" ]
	then
		dependency="tar"

	elif [ "${extension}" = "7z" ]
	then
		dependency="7z"

	elif [ "${extension}" = "rar" ]
	then
		dependency="rar"

	elif [ "${extension}" = "zip" ]
	then
		dependency="zip"
	else
		frobulator.err "Unsupported archive type" "[ '${archive}' ]"
		echo

		return 1
	fi

	frobulator.require "${dependency}"

	if [ "${?}" -ne 0 ]
	then
		return 1
	fi

	frobulator.inf "Archiving" "[ ${archive} ]"
	echo

	if [ "${extension}" = "tar.bz2" ] || [ "${extension}" = "tbz2" ]
	then
		tar												\
			--create									\
			--bzip2										\
			--file="${archive}"							\
			--directory="$(dirname "${directory}")"		\
			"$(basename "${directory}")"				> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${extension}" = "tar.gz" ] || [ "${extension}" = "tgz" ]
	then
		tar												\
			--create									\
			--gzip										\
			--file="${archive}"							\
			--directory="$(dirname "${directory}")"		\
			"$(basename "${directory}")"				> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${extension}" = "tar" ]
	then
		tar												\
			--create									\
			--file="${archive}"							\
			--directory="$(dirname "${directory}")"		\
			"$(basename "${directory}")"				> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${extension}" = "7z" ]
	then
		7z												\
			a											\
			"${archive}"								\
			"${directory}"								> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${extension}" = "rar" ]
	then
		rar												\
			a											\
			"${archive}"								\
			"${directory}"								> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${extension}" = "zip" ]
	then
		zip												\
			--quiet										\
			--recurse-paths								\
			"${archive}"								\
			"${directory}"								> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	fi

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "Archive creation failed" "[ '${archive}' ]"
		echo
	else
		frobulator.scs "Archive created" "[ '${archive}' ]"
		echo
	fi

	return "${status}"

}

# extract //////////////////////////////////////////////////////////////////////

# use to extract known archive types for script dependency or process resolution

# "${directory}" defaults to "${PWD}" when omitted

# "${extension}" assumes file name does not contain any periods '.'

# usage:      frobulator.extract "[archive]" "[directory]"

frobulator.extract () {

	local status=0

	local file="${1}"
	local directory="${2:-${PWD}}"
	local archive
	local extension
	local dependency

	if [ -z "${file}" ]
	then
		frobulator.err "No archive specified"
		echo

		return 1
	fi

	if [ ! -f "${file}" ]
	then
		frobulator.err "Unavailable" "[ '${file}' ]"
		echo

		return 1
	fi

	archive="${file##*/}"
	extension="${file#*.}"

	if [ ! -d "${directory}" ]
	then
		mkdir				\
			--parents		\
							"${directory}"

		if [ "${?}" -ne 0 ]
		then
			frobulator.err "Unable to create directory" "[ '${directory}' ]"
			echo

			return 1
		fi
	fi

	if [ "${extension}" = "tar.bz2" ] || \
	   [ "${extension}" = "tbz2"    ]
	then
		dependency="tar"

	elif [ "${extension}" = "tar.gz" ] || \
	     [ "${extension}" = "tgz"    ]
	then
		dependency="tar"

	elif [ "${extension}" = "tar" ]
	then
		dependency="tar"

	elif [ "${extension}" = "7z" ]
	then
		dependency="7z"

	elif [ "${extension}" = "rar" ]
	then
		dependency="unrar"

	elif [ "${extension}" = "zip" ]
	then
		dependency="unzip"
	else
		frobulator.err "Unsupported archive type" "[ '${archive}' ]"
		echo

		return 1
	fi

	frobulator.require "${dependency}"

	if [ "${?}" -ne 0 ]
	then
		return 1
	fi

	frobulator.inf "Extracting" "[ ${archive} ]"
	echo

	if [ "${extension}" = "tar.bz2" ] || [ "${extension}" = "tbz2" ]
	then
		tar									\
			--extract						\
			--no-same-owner					\
			--bzip2							\
			--file="${file}"				\
			--directory="${directory}"

	elif [ "${extension}" = "tar.gz" ] || [ "${extension}" = "tgz" ]
	then
		tar									\
			--extract						\
			--no-same-owner					\
			--gzip							\
			--file="${file}"				\
			--directory="${directory}"

	elif [ "${extension}" = "tar" ]
	then
		tar									\
			--extract						\
			--no-same-owner					\
			--file="${file}"				\
			--directory="${directory}"

	elif [ "${extension}" = "7z" ]
	then
		7z									\
			x								\
			"${file}"						\
			-o"${directory}"

	elif [ "${extension}" = "rar" ]
	then
		unrar								\
			e								\
			"${file}"						\
			"${directory}"

	elif [ "${extension}" = "zip" ]
	then
		unzip								\
			--overwrite						\
			--quiet							\
			"${file}"						\
			--directory "${directory}"
	fi

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "Archive extraction failed" "[ '${archive}' ]"
		echo
	else
		frobulator.scs "Archive extracted" "[ '${archive}' ]"
		echo
	fi

	return "${status}"
}

