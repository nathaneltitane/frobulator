# notify ///////////////////////////////////////////////////////////////////////
#
# framed message block with header:
# use to separate notices and messages from execution blocks
# supports message type designation for colorized output
#
#
# usage:	frobulator.ntf "title" "message"
#			frobulator.ntf [style] [split] [type] "title" "message"
#
# command:	frobulator.ntf style "title" "message"
# result:
#
# ┌────────────────────────────────────────────────────────────────────────────┐
# │ title                                                                      │
# ├────────────────────────────────────────────────────────────────────────────┤
# │ message                                                                    │
# └────────────────────────────────────────────────────────────────────────────┘
#
# command:	frobulator.ntf style split "title" "message"
# result:
#
# ┌────────────────────────────────────────────────────────────────────────────┐
# │ title                                                                      │
# └────────────────────────────────────────────────────────────────────────────┘
# ┌────────────────────────────────────────────────────────────────────────────┐
# │ message                                                                    │
# └────────────────────────────────────────────────────────────────────────────┘

frobulator.ntf () {

	local style
	local title
	local split
	local message
	local prompt_type
	local color

	local character_count
	local content_span
	local title_width
	local message_width

	local frame_horizontal_top
	local frame_horizontal_middle
	local frame_horizontal_bottom

	local frame_vertical_left
	local frame_vertical_right

	local frame_top_left
	local frame_top_right
	local frame_middle_left
	local frame_middle_right
	local frame_bottom_left
	local frame_bottom_right

	local frame_vertical_left_count
	local frame_vertical_right_count
	local marker_elp_count
	local marker_spc_count

	local line_top
	local line_middle
	local line_bottom

	local frame_top
	local frame_middle
	local frame_bottom

	local message_line

	style="square"

	title="Notice"

	split=""

	color=""

	# arguments

	while true
	do
		if [ "${1}" = "square" ] || \
		   [ "${1}" = "round"  ] || \
		   [ "${1}" = "heavy"  ] || \
		   [ "${1}" = "double" ] || \
		   [ "${1}" = "dots"   ] || \
		   [ "${1}" = "matrix" ] || \
		   [ "${1}" = "tech"   ] || \
		   [ "${1}" = "skel"   ] || \
		   [ "${1}" = "ascii"  ]
		then
			style="${1}"

			shift

		elif [ "${1}" = "split" ]
		then
			split="true"

			shift

		elif [ "${1}" = "nil" ] || \
			 [ "${1}" = "inf" ] || \
		     [ "${1}" = "wrn" ] || \
		     [ "${1}" = "msg" ] || \
		     [ "${1}" = "add" ] || \
		     [ "${1}" = "rem" ] || \
		     [ "${1}" = "ret" ] || \
		     [ "${1}" = "rel" ] || \
		     [ "${1}" = "fwd" ] || \
		     [ "${1}" = "rev" ] || \
		     [ "${1}" = "stp" ] || \
		     [ "${1}" = "dwl" ] || \
		     [ "${1}" = "upl" ] || \
		     [ "${1}" = "lnk" ] || \
		     [ "${1}" = "scs" ] || \
		     [ "${1}" = "err" ] || \
		     [ "${1}" = "ins" ] || \
		     [ "${1}" = "cpt" ] || \
		     [ "${1}" = "url" ]
		then
			prompt_type="${1}"

			shift

			frobulator."${prompt_type}" > ${sink}

			color=${color_entry[@]}

		else
			break
		fi
	done

	if [ $# -eq 0 ]
	then
		title="${title}"
		message=""

	elif [ $# -eq 1 ]
	then
		title="${title}"
		message="${1}"

	else
		title="${1}"

		shift

		if [ "${1}" = "split" ]
		then
			split="true"

			shift
		fi

		message="${@}"
	fi

	# columns

	if [ -z "${terminal_columns}" ]
	then
		character_count="${span_characters}"
	else
		character_count="${terminal_columns}"
	fi

	# default frame style

	frame_horizontal_top='─'
	frame_horizontal_middle='─'
	frame_horizontal_bottom='─'

	frame_vertical_left='│'
	frame_vertical_right='│'

	frame_top_left='┌'
	frame_top_right='┐'
	frame_middle_left='├'
	frame_middle_right='┤'
	frame_bottom_left='└'
	frame_bottom_right='┘'

	# alternate frame styles

	if [ "${style}" = "round" ]
	then
		frame_top_left='╭'
		frame_top_right='╮'
		frame_bottom_left='╰'
		frame_bottom_right='╯'

	elif [ "${style}" = "skel" ]
	then
		frame_vertical_left=' '
		frame_vertical_right=' '

	elif [ "${style}" = "heavy" ]
	then
		frame_horizontal_top='━'
		frame_horizontal_middle='━'
		frame_horizontal_bottom='━'

		frame_vertical_left='┃'
		frame_vertical_right='┃'

		frame_top_left='┏'
		frame_top_right='┓'
		frame_middle_left='┣'
		frame_middle_right='┫'
		frame_bottom_left='┗'
		frame_bottom_right='┛'

	elif [ "${style}" = "double" ]
	then
		frame_horizontal_top='═'
		frame_horizontal_middle='═'
		frame_horizontal_bottom='═'

		frame_vertical_left='║'
		frame_vertical_right='║'

		frame_top_left='╔'
		frame_top_right='╗'
		frame_middle_left='╠'
		frame_middle_right='╣'
		frame_bottom_left='╚'
		frame_bottom_right='╝'

	elif [ "${style}" = "ascii" ]
	then
		frame_horizontal_top='-'
		frame_horizontal_middle='-'
		frame_horizontal_bottom='-'

		frame_vertical_left='|'
		frame_vertical_right='|'

		frame_top_left='+'
		frame_top_right='+'
		frame_middle_left='+'
		frame_middle_right='+'
		frame_bottom_left='+'
		frame_bottom_right='+'

	elif [ "${style}" = "dots" ]
	then
		frame_horizontal_top='⠉'
		frame_horizontal_middle='⠒'
		frame_horizontal_bottom='⠤'

		frame_vertical_left='⠇'
		frame_vertical_right='⠸'

		frame_top_left='⠏'
		frame_top_right='⠹'
		frame_middle_left='⠗'
		frame_middle_right='⠺'
		frame_bottom_left='⠧'
		frame_bottom_right='⠼'

	elif [ "${style}" = "matrix" ]
	then
		frame_horizontal_top='▓'
		frame_horizontal_middle='▓'
		frame_horizontal_bottom='▓'

		frame_vertical_left='▓'
		frame_vertical_right='▓'

		frame_top_left='▓'
		frame_top_right='▓'
		frame_middle_left='▓'
		frame_middle_right='▓'
		frame_bottom_left='▓'
		frame_bottom_right='▓'

	elif [ "${style}" = "tech" ]
	then
		frame_vertical_left='║'
		frame_vertical_right='║'

		frame_top_left='╓'
		frame_top_right='╖'
		frame_middle_left='╟'
		frame_middle_right='╢'
		frame_bottom_left='╙'
		frame_bottom_right='╜'
	fi

	# width setup

	frame_vertical_left_count=${#frame_vertical_left}
	frame_vertical_right_count=${#frame_vertical_right}

	marker_elp_count=${#marker_elp}
	marker_spc_count=${#marker_spc}

	content_span=$(( character_count - frame_vertical_left_count - frame_vertical_right_count ))

	title_width=$(( content_span - marker_spc_count - marker_spc_count ))
	message_width=$(( content_span - marker_spc_count - marker_spc_count ))

	# horizontal frame setup

	while [ ${#line_top} -lt "${content_span}" ]
	do
		line_top="${line_top}${frame_horizontal_top}"
	done

	while [ ${#line_middle} -lt "${content_span}" ]
	do
		line_middle="${line_middle}${frame_horizontal_middle}"
	done

	while [ ${#line_bottom} -lt "${content_span}" ]
	do
		line_bottom="${line_bottom}${frame_horizontal_bottom}"
	done

	frame_top="${frame_top_left}${line_top}${frame_top_right}"
	frame_middle="${frame_middle_left}${line_middle}${frame_middle_right}"
	frame_bottom="${frame_bottom_left}${line_bottom}${frame_bottom_right}"

	# title frame

	echo "${frame_top}"

	title="${marker_spc}${title}${marker_spc}"

	if [ ${#title} -gt "${content_span}" ]
	then
		title="${title:0:$(( content_span - marker_elp_count - marker_spc_count ))}${marker_elp}${marker_spc}"
	fi

	while [ ${#title} -lt "${content_span}" ]
	do
		title="${title}${marker_spc}"
	done

	echo -e "${frame_vertical_left}${color}${title}${reset}${frame_vertical_right}"

	# message frame

	if [ -n "${message}" ]
	then
		if [ -n "${split}" ]
		then
			echo "${frame_bottom}"
			echo "${frame_top}"
		else
			echo "${frame_middle}"
		fi

		if [ ${#message} -gt "${message_width}" ]
		then
			message=$(echo "${message}" | fold -s -w "${message_width}")
		else
			message="${message}"
		fi

		while IFS= read -r message_line
		do
			message_line="${marker_spc}${message_line}"

			while [ ${#message_line} -lt "${content_span}" ]
			do
				message_line="${message_line}${marker_spc}"
			done

			message_line="${message_line:0:${content_span}}"

			echo -e "${frame_vertical_left}${color}${message_line}${reset}${frame_vertical_right}"

		done <<< "${message}"
	fi

	echo "${frame_bottom}"

	# cleanup

	unset style
	unset title
	unset split
	unset message
	unset prompt_type
	unset color

	unset character_count
	unset content_span
	unset title_width
	unset message_width

	unset frame_horizontal_top
	unset frame_horizontal_middle
	unset frame_horizontal_bottom

	unset frame_vertical_left
	unset frame_vertical_right

	unset frame_top_left
	unset frame_top_right
	unset frame_middle_left
	unset frame_middle_right
	unset frame_bottom_left
	unset frame_bottom_right

	unset frame_vertical_left_count
	unset frame_vertical_right_count
	unset marker_elp_count
	unset marker_spc_count

	unset line_top
	unset line_middle
	unset line_bottom

	unset frame_top
	unset frame_middle
	unset frame_bottom

	unset message_line

	unset IFS
}

# separate /////////////////////////////////////////////////////////////////////

# use to separate instructions or warnings from prompts

# note:
# set up as predefined separator

# usage:      frobulator.separate

# command:    frobulator.separate
# result:     ////////////////////////////////////////////////////////////...///

frobulator.separate () {

	frobulator.sep

	echo
}

# read /////////////////////////////////////////////////////////////////////////

# use to capture user input through frobulator.ask / frobulator.interrupt

# sets newline for next prompt clearance

frobulator.read () {

	read ${@}

	echo
}

# script ///////////////////////////////////////////////////////////////////////

# use to mark the beginning of a script process
# derives title from script name:
# script name must be separated with '-' character as 'script-name'

# usage:      frobulator.script

# command:    frobulator.script "Setting up ${script#*-}"
# result:     [ # ] Setting up 'script' //////////////////.../// [ script name ]

frobulator.script () {

	description="${1}"

	if [[ "${script}" = *-* ]]
	then
		message="${script%-*}${marker_spc}${marker_spc}${marker_hnt}${marker_spc}${marker_spc}${version}"
	else
		message="${script}"
	fi

	frobulator.msg "${description}" "[ ${message} ]"

	echo
}

# type /////////////////////////////////////////////////////////////////////////

# use to emulate typing on prompts:
# timeout is randomized to create human-like typing effect
# interval value must be an integer

# usage:      frobulator.type "[interval]" "[string]"

frobulator.type () {

	string="${1}"
	interval="${2}"

	string_length=${#string}

	if [ -z "${interval}" ]
	then
		interval=2
	fi

	for (( characters=0 ; characters<=${string_length} ; characters++ ))
	do
		decimal=$(( (RANDOM % ${interval}) + 1 ))

		seconds="0.${decimal}"

		echo -n -e "${1:${characters}:1}"

		sleep "${seconds}"
	done

	echo
}

# timeout //////////////////////////////////////////////////////////////////////

# use to mark timeout in between commands in seconds

# usage:      frobulator.timeout "[seconds]"

frobulator.timeout () {

	seconds="${1}"

	# set defaults

	if [ -z "${seconds}" ]
	then
		seconds="1"
	fi

	sleep "${seconds}"
}

# clear ////////////////////////////////////////////////////////////////////////

# use for script process 'paging':
# clears previous step when all checkpoint markers are met

frobulator.clear () {

	frobulator.timeout

	clear
}

# countdown ////////////////////////////////////////////////////////////////////

# use as countdown marker before next command runs:
# leaves preset time for long interaction with prompts and other long strings

# usage:      frobulator.countdown "[seconds]" "[string]" "[string]"

frobulator.countdown () {

	local status=0

	local counter="${1}"
	local seconds=1
	local ticker
	local prompt
	local before="[${marker_spc}${marker_spc}"
	local after="${marker_spc}${marker_spc}]"

	shift

	if [ -z "${counter}" ]
	then
		frobulator.err "No countdown specified"
		echo

		return 1
	fi

	if [[ ! "${counter}" =~ ^[0-9]+$ ]]
	then
		frobulator.err "Invalid countdown" "[ ${counter} ]"
		echo

		return 1
	fi

	frobulator.pmt "${@}"

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	prompt="${prompt_string[*]}"

	while [ "${counter}" -ge 0 ]
	do
		if [ "${counter}" -eq 0 ]
		then
			ticker="-"

			echo -n -e "\r${before}${orange}${ticker}${reset}${after}${marker_spc}${prompt}\c"

			break
		else
			echo -n -e "\r${before}${red}${counter}${reset}${after}${marker_spc}${prompt}\c"

			counter=$(( counter - 1 ))
		fi

		sleep "${seconds}"

		if [ "${?}" -ne 0 ]
		then
			status=1

			break
		fi
	done

	echo
	echo

	return "${status}"

}

# actions //////////////////////////////////////////////////////////////////////

# action verbage parser:
# handles simple action verb placement and syntax substitution

# use in frobulator action calls in frobulator.progress

frobulator.action () {

	local status=0

	local action="${1}"
	local color
	local progress_detail

	local -a detail=()

	local -a color_list=(
		"${magenta}"
		"${purple}"
		"${blue}"
		"${navy}"
		"${red}"
		"${crimson}"
		"${yellow}"
		"${orange}"
		"${aqua}"
		"${teal}"
		"${black}"
		"${green}"
		"${lime}"
		"${silver}"
		"${grey}"
	)

	if [ "${#}" -gt 0 ]
	then
		shift
	fi

	detail=("${@}")

	# set action fallback

	if [ -z "${action}" ]
	then
		action="frobulate"
	fi

	action="${action,,}"

	# select random action color

	color="${color_list[RANDOM % ${#color_list[@]}]}"

	# conjugate action

	action="${action^}"

	if [ "${action: -2}" = "ie" ]
	then
		action="${action/%ie/y}"

	elif [ "${action: -2}" = "ee" ]
	then
		:

	elif [ "${action: -2}" = "ue" ]
	then
		:

	elif [ "${action: -1}" = "e" ]
	then
		action="${action/%e/}"

	elif [ "${action: -1}" = "c" ]
	then
		action="${action}k"

	elif [[ "${action}" =~   [aeiou][bcdfghjklmnpqrstvwxyz]$        ]] && \
	     [[ ! "${action}" =~ [aeiou][aeiou][bcdfghjklmnpqrstvwxyz]$ ]] && \
	     [[ ! "${action}" =~ [wxy]$ ]]
	then
		action="${action}${action: -1}"
	fi

	action="${action}ing"

	if [ "${#detail[@]}" -eq 0 ]
	then
		action="${action}${marker_elp}"
	fi

	# generate prompt

	if [ "${#detail[@]}" -gt 0 ]
	then
		progress_detail="${detail[*]}"

		frobulator.pmt "${action}" "${progress_detail}"
	else
		frobulator.pmt "${action}"
	fi

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	progress_prompt="${prompt_string[*]}"
	progress_color="${color}"

	return "${status}"

}

# process //////////////////////////////////////////////////////////////////////

# use as ticker line marker to mark process completion or progress
# use after process marked for background operation

# usage:      [process] &
#             frobulator.process "[string]"

frobulator.process () {

	# capture process identifier of last background command

	local PID=${!}
	local status
	local seconds="0.25"
	local ticker='/\'
	local before="[${marker_spc}${marker_spc}"
	local after="${marker_spc}${marker_spc}]"
	local prompt
	local ticker_frame
	local instance=1

	if [ -z "${PID}" ]
	then
		frobulator.err "No background process detected"
		echo

		return 1
	fi

	frobulator.pmt "${@}"

	prompt="${prompt_string[@]}"

	while [ -d "/proc/${PID}" ]
	do
		ticker_frame="${ticker:instance++%${#ticker}:1}"

		echo -n -e "\r${before}${color} \b${ticker_frame}${reset}${after}${marker_spc}${prompt}\c"

		sleep "${seconds}"
	done

	wait "${PID}"

	status="${?}"

	echo
	echo

	return "${status}"
}

# progress /////////////////////////////////////////////////////////////////////

# use as ticker line marker to mark process wait progress
# use after process marked to for in background
# refer to frobulator.action for actions list

# usage:      [process] &
#             frobulator.progress "[action]"

frobulator.progress () {

	# capture process identifier of last background command

	local PID=${!}
	local status
	local seconds="0.25"
	local ticker='⎺⎻⎼⎽⎼⎻'
	local before="[${marker_spc}${marker_spc}"
	local after="${marker_spc}${marker_spc}]"
	local instance=1
	local ticker_frame

	if [ -z "${PID}" ]
	then
		frobulator.err "No background process detected"
		echo

		return 1
	fi

	frobulator.action "${@}"

	while [ -d "/proc/${PID}" ]
	do
		ticker_frame="${ticker:instance++%${#ticker}:1}"

		echo -n -e "\r${before}${progress_color} \b${ticker_frame}${reset}${after}${marker_spc}${progress_prompt}\c"

		sleep "${seconds}"
	done

	wait "${PID}"

	status="${?}"

	unset color_entry
	unset progress_prompt
	unset progress_color

	echo
	echo

	return "${status}"
}

# bar //////////////////////////////////////////////////////////////////////////

# use to run a command with an estimated activity bar

# note:
#	        not a true progress meter
#	        estimates progress while the process is running
#	        only reaches 100 percent when the process exits

# usage:
#	        frobulator.bar sleep 5
#	        frobulator.bar apt-get update
#	        frobulator.bar rsync -av source/ destination/

frobulator.bar () {

	local command

	local process_id
	local process_exit

	local seconds

	local character_count
	local before_count
	local after_count
	local buffer_count

	local progress_current
	local progress_limit
	local progress_percent

	local progress_done
	local progress_left

	local progress_done_line
	local progress_left_line
	local progress_line

	local progress_label

	local job_control

	if [ $# -eq 0 ]
	then
		frobulator.err "Missing command"
		echo

		return 1
	fi

	# defaults

	seconds="0.25"

	progress_current=0
	progress_limit=99

	# columns

	if [ -z "${terminal_columns}" ]
	then
		character_count="${span_characters}"
	else
		character_count="${terminal_columns}"
	fi

	# reserved output width

	before_count=0
	after_count=8

	buffer_count=$(( character_count - before_count - after_count ))

	# run command

	command=${@}

	"${SHELL}" -c "${command}" >> "${sink}" 2>&1 &

	process_id=$!

	# monitor process

	while [ -d /proc/"${process_id}" ]
	do
		# simulated progress

		if [ "${progress_current}" -lt 70 ]
		then
			progress_current=$(( progress_current + 2 ))

		elif [ "${progress_current}" -lt 90 ]
		then
			progress_current=$(( progress_current + 1 ))

		elif [ "${progress_current}" -lt "${progress_limit}" ]
		then
			progress_current=$(( progress_current + 0 ))

		fi

		# progress calculation

		progress_percent="${progress_current}"

		progress_done=$(( progress_percent * buffer_count / 100 ))
		progress_left=$(( buffer_count - progress_done ))

		# progress line

		progress_done_line=$(printf "%${progress_done}s")
		progress_left_line=$(printf "%${progress_left}s")

		progress_done_line="${progress_done_line// /|}"
		progress_left_line="${progress_left_line// /-}"

		progress_line="${progress_done_line}${progress_left_line}"

		# percentage padding

		if [ "${progress_percent}" -lt 10 ]
		then
			progress_label="00${progress_percent}"

		elif [ "${progress_percent}" -lt 100 ]
		then
			progress_label="0${progress_percent}"

		else
			progress_label="${progress_percent}"
		fi

		# output

		echo -n -e "\r[${marker_spc}${progress_label}${marker_spc}${progress_line}${marker_spc}]"

		sleep "${seconds}"
	done

	# collect exit code

	wait ${process_id}

	process_exit=$?

	# force completion

	progress_percent=100

	progress_done=$(( progress_percent * buffer_count / 100 ))
	progress_left=$(( buffer_count - progress_done ))

	progress_done_line=$(printf "%${progress_done}s")
	progress_left_line=$(printf "%${progress_left}s")

	progress_done_line="${progress_done_line// /|}"
	progress_left_line="${progress_left_line// /-}"

	progress_line="${progress_done_line}${progress_left_line}"

	progress_label="100"

	# final output

	if [ "${process_exit}" -eq 0 ]
	then
		echo -n -e "\r[${marker_spc}${progress_label}${marker_spc}${progress_line}${marker_spc}]"
	fi

	echo
	echo

	# cleanup

	unset command

	unset process_id
	unset process_exit

	unset seconds

	unset character_count
	unset before_count
	unset after_count
	unset buffer_count

	unset progress_current
	unset progress_limit
	unset progress_percent

	unset progress_done
	unset progress_left

	unset progress_done_line
	unset progress_left_line
	unset progress_line

	unset progress_label

	return ${process_exit}

}

# temporary ////////////////////////////////////////////////////////////////////

# use to generate temporary directory from argument or array list
# generates directory template as 'frobulator_temporary_XXXXXX'
# useful for program builds and process transfer features

# usage:      frobulator.temporary "[directory name]" | "[array name]"

frobulator.temporary () {

	local status=0

	if [[ "${#list[@]}" -gt 0 ]]
	then
		# ${1} - array

		list=("${@:1}")
	else
		directory="${1}"

		list=()

		list+=("${directory}")
	fi

	template="frobulator.tmp.XXXXXX"

	for directory in "${list[@]}"
	do
		temporary_directory=$(mktemp -d -t "${template}")

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		eval directory="${temporary_directory}"

		frobulator.add "Generating temporary directory" "[ ${directory} ]"
		echo

		frobulator_return+=("${directory}")
	done

	list=()

	return "${status}"
}

# trap /////////////////////////////////////////////////////////////////////////

# use to cleanup temporary directory or other process driven execution
# handles exit codes and signals to ensure proper cleanup
# specify directory name as variable
# variable is returned from 'eval' into frobulator.temporary

# usage:         frobulator.temporary "[directory name]" | "[array name]"
# assignment:    directory="${frobulator_return[@]}"
#                frobulator.trap "${directory name}"

# signal        value    action    comment
# ------------------------------------------------------------------------------
# SIGTERM       15       Term      Termination signal
# SIGINT         2       Term      CONTROL+C interrupt from keyboard
# SIGHUP         1       Term      Disconnected terminal or parent died
# SIGPIPE       13       Term      Broken pipe
# SIGALRM(*)    14       Term      Timer signal from alarm
# SIGUSR2(*)    12       Term      User-defined signal 2
# SIGUSR1(*)    10       Term      User-defined signal 1
# SIGQUIT        3       Core      CONTRL+\ or quit from keyboard
# SIGABRT        6       Core      Abort signal from abort(3)
# SIGSEGV       11       Core      Invalid memory reference
# SIGILL         4       Core      Illegal Instruction
# SIGFPE         8       Core      Floating point exception
# SIGKILL        9       Term      Kill signal
# ------------------------------------------------------------------------------

frobulator.trap () {

	local status=0

	if [[ "${#list[@]}" -gt 0 ]]
	then
		# ${1} - array

		list=("${@:1}")
	else
		directory="${1}"

		list=()

		list+=("${directory}")
	fi

	for directory in "${list[@]}"
	do
		# clean on interruption or error

		trap "exit 1" HUP INT PIPE QUIT TERM

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

		# clean on exit

		trap 'rm --recursive --force "${directory}"' EXIT

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

# complete /////////////////////////////////////////////////////////////////////

# BASH exit status codes -------------------------------------------------------

# exit status codes are integers returned by commands upon completion
# a successful command typically returns an exit status of 0
# non-zero values generally indicate an error or abnormal termination

# common exit status codes -----------------------------------------------------

# code     definition                           example

# 0        success                              true
# 1        generic error                        false
# 2        misuse of shell builtins             'cd /nonexistent/directory'

# 126      command invoked cannot execute       'bash /nonexistent_script'    (assume script lacks executable permissions)
# 127      command not found                    'nonexistent_command'
# 128+n    fatal error - signal "n"             'kill -9 $$'                  (send SIGKILL to current process)
# 130      terminated  - signal 2 (sigint)      'kill -2 $!'                  (send SIGINT to background process)
# 137      terminated  - signal 9 (sigkill)     'kill -9 $!'                  (send SIGKILL to background process)
# 139      terminated  - signal 11 (sigsegv)                                  (program with memory access violations)
# 143      terminated  - signal 15 (sigterm)    'kill -15 $!'                 (send SIGTERM to background process)

# 255*     out of range - exit -1

# complete ---------------------------------------------------------------------

# frobulator.complete
#         │
#         ├── capture previous command status
#         │       or
#         ├── execute command
#         ├── record checkpoint
#         ├── record status
#         └── continue execution
#                     │
#                     ▼
#            frobulator.result
#                     │
#                     ├── summarize statuses
#                     ├── clear checkpoints
#                     ├── clear statuses
#                     └── return overall status

# capture previous command status when used without arguments
# execute command and record checkpoint status when arguments are supplied
# skip execution when checkpoint already completed successfully
# use immediately after command when used without arguments
# use in tandem with frobulator.result

# usage:    command
#           frobulator.complete

#           frobulator.complete "[path]" "[checkpoint]" command [arguments...]

frobulator.complete () {

	local previous_status="${?}"

	local status=0

	local path
	local checkpoint
	local checkpoint_number

	# initialize collections

	if [ -z "${frobulator_complete_initialized}" ]
	then
		frobulator_complete_statuses=()
		frobulator_complete_checkpoints=()

		frobulator_complete_initialized=true
	fi

	# collect previous command status

	if [ "${#}" -eq 0 ]
	then
		checkpoint_number=$(( ${#frobulator_complete_checkpoints[@]} + 1 ))

		checkpoint="operation ${checkpoint_number}"
		status="${previous_status}"

		frobulator_complete_statuses+=("${status}")
		frobulator_complete_checkpoints+=("${checkpoint}")

		if [ "${status}" -eq 0 ]
		then
			frobulator.cpt "Complete" "[ ${status} ] [ ${checkpoint} ]"
			echo
		else
			frobulator.wrn "Incomplete" "[ ${status} ] [ ${checkpoint} ]"
			echo
		fi

		return 0
	fi

	# assign checkpoint parameters

	path="${1}"
	checkpoint="${2}"

	shift 2

	# validate path

	if [ -z "${path}" ]
	then
		frobulator_complete_statuses+=("1")
		frobulator_complete_checkpoints+=("undefined checkpoint path")

		frobulator.err "Checkpoint path not defined"
		echo

		return 0
	fi

	# validate checkpoint

	if [ -z "${checkpoint}" ]
	then
		frobulator_complete_statuses+=("1")
		frobulator_complete_checkpoints+=("undefined checkpoint")

		frobulator.err "Checkpoint not defined"
		echo

		return 0
	fi

	# validate command

	if [ "${#}" -eq 0 ]
	then
		frobulator_complete_statuses+=("1")
		frobulator_complete_checkpoints+=("${checkpoint}")

		frobulator.err "Command not defined" "[ ${status} ] [ ${checkpoint} ]"
		echo

		return 0
	fi

	# check checkpoint

	if [ -f "${path}/${checkpoint}" ]
	then
		frobulator_complete_statuses+=("0")
		frobulator_complete_checkpoints+=("${checkpoint}")

		frobulator.cpt "Complete" "[ ${status} ] [ ${checkpoint} ]"
		echo

		return 0
	fi

	# run command

	"${@}"

	status="${?}"

	# collect status

	frobulator_complete_statuses+=("${status}")
	frobulator_complete_checkpoints+=("${checkpoint}")

	# manage checkpoint

	if [ "${status}" -eq 0 ]
	then
		frobulator.file "${path}" "${checkpoint}"

		if [ "${?}" -ne 0 ]
		then
			status=1

			frobulator_complete_statuses[-1]="${status}"

			frobulator.err "Checkpoint creation failed" "[ ${status} ] [ ${checkpoint} ]"
			echo
		else
			frobulator.cpt "Complete" "[ ${status} ] [ ${checkpoint} ]"
			echo
		fi
	else
		if [ -f "${path}/${checkpoint}" ]
		then
			rm --force -- "${path}/${checkpoint}"

			if [ "${?}" -ne 0 ]
			then
				status=1

				frobulator_complete_statuses[-1]="${status}"
			fi
		fi

		frobulator.wrn "Incomplete" "[ ${status} ] [ ${checkpoint} ]"
		echo
	fi

	# continue process

	return 0
}

# result ///////////////////////////////////////////////////////////////////////

# frobulator.result
#         │
#         ├── evaluate recorded statuses
#         ├── count failed checkpoints
#         ├── report final outcome
#         ├── clear recorded collections
#         └── return overall status

# evaluate statuses collected by frobulator.complete:
# report success when all checkpoints completed successfully
# report failure count when one or more checkpoints failed
# clear checkpoint and status collections after evaluation
# use in tandem with frobulator.complete

# usage:      frobulator.result "[instance]"

frobulator.result () {

	local status=0

	local count_error=0

	local instance="${1}"
	local complete_status

	# evaluate statuses

	for complete_status in "${frobulator_complete_statuses[@]}"
	do
		if [ "${complete_status}" -ne 0 ]
		then
			status=1

			count_error=$(( count_error + 1 ))
		fi
	done

	# clear collections

	frobulator_complete_statuses=()
	frobulator_complete_checkpoints=()

	# report result

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "Setup incomplete" "[ ${instance} ]"
		echo

		frobulator.wrn "Errors encountered" "[ ${count_error} ] [ ${instance} ]"
		echo

		frobulator.inf "Review setup logs for details" "[ ${PREFIX}/var/log/ ]"
		echo
	else
		frobulator.scs "Setup complete" "[ ${instance} ]"
		echo
	fi

	return "${status}"

}

# ownership ////////////////////////////////////////////////////////////////////

# use to restore ownership after privileged operations

# usage:      frobulator.ownership [target]

frobulator.ownership () {

	local status=0

	local target
	local user_name
	local user_home
	local target_path
	local system_path
	local path
	local owner_name
	local user_id
	local group_id

	local system_paths_list=(
		/root
		/usr
		/etc
		/var
		/opt
		/boot
	)

	if [ "${#}" -eq 0 ]
	then
		frobulator.err "Missing ownership target"
		echo

		return 1
	fi

	list=("${@}")

	# determine user ownership source

	if [ -n "${SUDO_USER}" ]
	then
		user_name="${SUDO_USER}"
	else
		user_name="$(id -u -n)"

		if [ "${?}" -ne 0 ]
		then
			list=()

			return 1
		fi
	fi

	# determine user home

	user_home="/home/${user_name}"

	if [ "${user_name}" = "root" ]
	then
		user_home="/root"
	fi

	for target in "${list[@]}"
	do
		system_path="false"

		# resolve target path

		target_path="$(realpath -m "${target}")"

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		for path in "${system_paths_list[@]}"
		do
			if [[ "${target_path}" = "${path}"   ]] || \
			   [[ "${target_path}" = "${path}/"* ]]
			then
				system_path="true"

				break
			fi
		done

		# determine ownership context

		if [[ "${target_path}" = "${user_home}"   ]] || \
		   [[ "${target_path}" = "${user_home}/"* ]]
		then
			owner_name="${user_name}"

		elif [ "${system_path}" = "true" ]
		then
			owner_name="root"

		else
			owner_name="${user_name}"
		fi

		# resolve ownership identities

		user_id="$(id -u "${owner_name}")"

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		group_id="$(id -g "${owner_name}")"

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		# apply ownership

		chown							\
			"${user_id}:${group_id}"	\
			--recursive					\
										"${target}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"
}

# directory ////////////////////////////////////////////////////////////////////

# use to generate directory from argument or array list

# "${path}" defaults to "${PWD}" when omitted

# usage:      frobulator.directory "[/path/string]" | "[path]" "[directory name]" | "[array name]"

frobulator.directory () {

	local status=0

	local path
	local directory
	local directory_item

	if [ "${#}" -eq 1 ]
	then
		if [[ "${1}" = */* ]]
		then
			path="${1%/*}"

			directory_item="${1##*/}"
		else
			path="${PWD}"

			directory_item="${1}"
		fi

		list=()

		list+=("${directory_item}")
	fi

	if [ "${#}" -ge 2 ]
	then
		path="${1}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			directory_item="${2}"

			list=()

			list+=("${directory_item}")
		fi

		shift
	fi

	for directory in "${list[@]}"
	do
		frobulator.add "Generating directory" "[ ${directory} ]"
		echo

		# create directory and set permissions

		if [ ! -d "${path}/${directory}" ]
		then
			mkdir --parents "${path}/${directory}"

			if [ "${?}" -ne 0 ]
			then
				status=1

				continue
			fi
		fi

		# set ownership

		frobulator.ownership "${path}/${directory}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

# write ////////////////////////////////////////////////////////////////////////

# use to generate and write to file(s) from argument or array list
# appends content to file

# "${path}" defaults to "${PWD}" when omitted

# usage:      frobulator.write "[content]" "[path]" "[file]"

frobulator.write () {

	local status=0

	local content="${1}"
	local path
	local file

	if [ "${#}" -eq 2 ]
	then
		path="${PWD}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			file="${2}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ "${#}" -eq 3 ]
	then
		path="${2}"

		if [ -z "${path}" ]
		then
			path="${PWD}"
		fi

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${3} - array

			list=("${@:3}")
		else
			file="${3}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ ! -d "${path}" ]
	then
		mkdir --parents "${path}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	for file in "${list[@]}"
	do
		frobulator.add "Writing" "[ ${file} ]"
		echo

		# write to file and set permissions

		echo "${content}" >> "${path}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		# set ownership

		frobulator.ownership "${path}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

