#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

# script ///////////////////////////////////////////////////////////////////////

# version //////////////////////////////////////////////////////////////////////

# version="07-22-2026"

# variables ////////////////////////////////////////////////////////////////////

stamp=$(date +"%m-%d-%Y-%H-%M-%S")

# script ///////////////////////////////////////////////////////////////////////

script="$(basename -- ${BASH_SOURCE[0]})"

# defaults /////////////////////////////////////////////////////////////////////

self="${BASH_SOURCE[0]}"

# usage ////////////////////////////////////////////////////////////////////////

if [[ "${self}" = "${0}" ]]
then
	# implement from local version

	if [ $# -eq 0 ]
	then
		source "${self}"

		return 0 2> "${sink}"

		if [ "${?}" -ne 0 ]
		then
			frobulator.scs "Implemented" "[ ${PWD}/${self} ]"
			echo
		fi
	fi

	file_source="${self}"

	file_install="${file_source}"

	directory_install="${HOME}"/.local/bin

	file_target="${directory_install}/${file_install}"

	while (($#))
	do
		case "${1}" in

			-i|--install)

				if [ ! -d "${directory_install}" ]
				then
					mkdir -p "${directory_install}"
				fi

				if [ "${file_source}" != "${file_target}" ]
				then
					cp "${file_source}" "${file_target}"

					chmod a+rx "${file_target}"

					source "${file_target}"

					frobulator.scs "Installed" "[ ${file_target} ]"

					echo
				fi
			;;

			-h|--help)

				echo
				echo -e "Usage: ./${script} | [OPTION]"
				echo
				echo "Options:"
				echo
				echo "	-i, --install    [I]nstall "${script}" to ${directory_install}"
				echo "	-h, --help       Show this [h]elp menu"
				echo

				exit
			;;

			*)

				echo
				echo "${script}: Unknown option '${1}'"
				echo "Type './${script} --help' for help and usage information."
				echo

				exit 1
			;;

		esac

		shift

	done
fi

# requirements /////////////////////////////////////////////////////////////////

# provide system shell

if [ -z "${SHELL}" ]
then
	if [[ $(command -v /bin/bash) ]]
	then
		SHELL=$(command -v /bin/bash)
	else
		SHELL=$(command -v /usr/bin/bash)
	fi
else
	SHELL="${SHELL}"
fi

# provide terminal columns count

terminal_columns=80

# provide fallback for non 'root' assessments

self="${0}"

if [ -z "${script}" ]
then
	script="${self}"
fi

# provide null sink for argument / error / output silencing

if [ -e /dev/null ]
then
	sink="/dev/null"
fi

# package manager //////////////////////////////////////////////////////////////

# detect package manager

if [[ $(command -v apt) ]]
then
	package_manager="apt"

elif [[ $(command -v dnf) ]]
then
	package_manager="dnf"

elif [[ $(command -v yum) ]]
then
	package_manager="yum"

elif [[ $(command -v pip) ]]
then
	package_manager="pip"

elif [[ $(command -v pipx) ]]
then
	package_manager="pipx"
fi

