frobulator.flag () {

	local status=0

	local content="${1}"
	local path
	local file

	if [ "${#}" -eq 2 ]
	then
		path="${PWD}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			file="${2}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ "${#}" -eq 3 ]
	then
		path="${2}"

		if [ -z "${path}" ]
		then
			path="${PWD}"
		fi

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${3} - array

			list=("${@:3}")
		else
			file="${3}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ ! -d "${path}" ]
	then
		mkdir --parents "${path}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	for file in "${list[@]}"
	do
		frobulator.add "Flagging" "[ ${file} ]"
		echo

		# write to file and set permissions

		echo "${content}" > "${path}/${file}"

		if [ "${?}" -ne 0 ]
