	else
		frobulator.wrn "This utility must be run using the 'directory' option"
		echo

		frobulator.fwd "Exiting${marker_elp}"
		echo

		return 1
	fi

	return "${status}"

}

# terminate ////////////////////////////////////////////////////////////////////

# use to forcefully terminate rogue processes

# usage:      frobulator.terminate "[process]"

# terminate ////////////////////////////////////////////////////////////////////

frobulator.terminate () {

	local status=0

	local process_name="${1}"

	if [ -z "${process_name}" ]
	then
		frobulator.err "No process specified"
		echo

		return 1
	fi

	if [ -z "$(command -v pgrep)" ]
	then
		frobulator.err "Command not available" "[ 'pgrep' ]"
		echo

		return 1
	fi

	if [ -z "$(command -v pkill)" ]
	then
		frobulator.err "Command not available" "[ 'pkill' ]"
		echo

		return 1
	fi

	while [ -n "$(pgrep -f "${process_name}")" ]
	do
		pkill -f "${process_name}"

		if [ "${?}" -ne 0 ]
		then
			status=1

			break
		fi
	done

	return "${status}"

}

