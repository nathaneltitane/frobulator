			row="${1}"
			col="${2}"

			if [[ "${row}" =~ ^[0-9]+$ ]] && [[ "${column}" =~ ^[0-9]+$ ]]
			then
				tput cup "${row}" "${column}"
			else
				echo "terminal_cursor_move: invalid row/column input: '${row}' '${column}'" >&2

				return 1
			fi
		}

		# move cursor down (row)

		terminal_cursor_down () {

			local rows="${1:-1}"

			if [[ "${rows}" =~ ^[0-9]+$ ]]
			then
				tput cud "${rows}"
			else
				echo "terminal_cursor_up: invalid row input: '${rows}'" >&2

				return 1
			fi
		}

		# move cursor up (row)

		terminal_cursor_up () {

			local rows="${1:-1}"

			if [[ "${rows}" =~ ^[0-9]+$ ]]
			then
				tput cuu "${rows}"
			else
				echo "terminal_cursor_up: invalid row input: '${rows}'" >&2

				return 1
			fi
		}

