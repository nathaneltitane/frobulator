		fi
	done

	# unset array

	list=()

	return "${status}"

}

# file /////////////////////////////////////////////////////////////////////////

# use to generate file(s) from argument or array list

# usage:      frobulator.file "[path]" "[file]" | "[array]"

frobulator.file () {

	local status=0

	local path
	local file

	if [ "${#}" -eq 1 ]
	then
		path="${PWD}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${1} - array

			list=("${@:1}")
		else
			file="${1}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ "${#}" -eq 2 ]
	then
		path="${1}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			file="${2}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ ! -d "${path}" ]
	then
		mkdir --parents "${path}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	for file in "${list[@]}"
	do
		frobulator.add "Generating" "[ ${file} ]"
		echo

		# create file and set permissions

		if [ ! -f "${path}/${file}" ]
		then
			touch "${path}/${file}"

			if [ "${?}" -ne 0 ]
			then
				status=1

				continue
			fi
		fi

		# set ownership

		frobulator.ownership "${path}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

# keep /////////////////////////////////////////////////////////////////////////

# use to reverse-select file(s) for deletion from argument or array list
# keeps selected files in directory

# usage:      frobulator.keep "[path]" "[file]" | "[array]"

frobulator.keep () {

	local status=0

	local path
	local file
	local item
	local keep

	if [ "${#}" -eq 1 ]
	then
		path="${PWD}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${1} - array

			list=("${@:1}")
		else
			file="${1}"

			list=()

			list+=("${file}")
		fi
	fi

	if [ "${#}" -ge 2 ]
	then
		path="${1}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			file="${2}"

			list=()

			list+=("${file}")
		fi

		shift
	fi

	if [ -d "${path}" ]
	then
		# enter path and parse items

		cd "${path}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi

		for item in *
		do
			keep=0

			for file in "${list[@]}"
			do
				# mark for keeping

				if [[ "${path}/${file}" = "${path}/${item}" ]]
				then
					keep=1

					frobulator.ret "Keeping" "[ ${file} ]"
					echo
				fi
			done

			# remove unmarked items

			if [ "${keep}" -eq 0 ]
			then
				rm --recursive --force "${path}/${item}"

				if [ "${?}" -ne 0 ]
				then
					status=1
				fi
			fi
		done
	else
		frobulator.err "Path does not exist" "[ ${path} ]"
		echo

		return 1
	fi

	# unset array

	list=()

	return "${status}"
}

# delete ///////////////////////////////////////////////////////////////////////

# use to select file(s) for deletion from argument or array list
# removes selected file in directory

# usage:      frobulator.delete "[path]" "[file]" | "[array]"

frobulator.delete () {

	local status=0

	local path
	local item

	if [ "${#}" -eq 1 ]
	then
		path="${PWD}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${1} - array

			list=("${@:1}")
		else
			item="${1}"

			list=()

			list+=("${item}")
		fi
	fi

	if [ "${#}" -eq 2 ]
	then
		path="${1}"

		if [[ "${#list[@]}" -gt 0 ]]
		then
			# ${2} - array

			list=("${@:2}")
		else
			item="${2}"

			list=()

			list+=("${item}")
		fi
	fi

	for item in "${list[@]}"
	do
		frobulator.rem "Deleting" "[ ${item} ]"
		echo

		# remove file

		rm --recursive --force "${path}/${item}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

# copy /////////////////////////////////////////////////////////////////////////

# use to copy file(s) and/or diretories from argument or array list

# usage:      frobulator.copy "[source]" "[target]" "[file]" | "[array]"

frobulator.copy () {

	local status=0

	local source="${1}"
	local target="${2}"
	local file

	if [[ "${#list[@]}" -gt 0 ]]
	then
		# ${3} - array

		list=("${@:3}")
	else
		file="${3}"

		list=()

		list+=("${file}")
	fi

	if [ ! -d "${target}" ]
	then
		mkdir --parents "${target}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	for file in "${list[@]}"
	do
		frobulator.lnk "Copying" "[ ${file} ]"
		echo

		cp --recursive --force "${source}/${file}" "${target}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"
}

# move /////////////////////////////////////////////////////////////////////////

# use to move file(s) and/or diretories from argument or array list

# usage:      frobulator.move "[source]" "[target]" "[file]" | "[array]"

frobulator.move () {

	local status=0

	local source="${1}"
	local target="${2}"
	local file

	if [[ "${#list[@]}" -gt 0 ]]
	then
		# ${3} - array

		list=("${@:3}")
	else
		file="${3}"

		list=()

		list+=("${file}")
	fi

	if [ ! -d "${target}" ]
	then
		mkdir --parents "${target}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	for file in "${list[@]}"
	do
		if [ -z "${source}" ]
		then
			source="${PWD}"
		fi

		frobulator.lnk "Moving" "[ ${file} ]"
		echo

		mv "${source}/${file}" "${target}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1

			continue
		fi

		# set permissions

		chmod a+rx "${target}/${file}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	return "${status}"

}

# link /////////////////////////////////////////////////////////////////////////

# use to link file(s) and/or diretories from argument or array list

# usage:      frobulator.link "[source]" "[target]" "[item]" | "[array]"

frobulator.link () {

	local status=0

	local source="${1}"
	local target="${2}"
	local item
	local link
	local type

	# validation

	if [ -z "${source}" ] || [ -z "${target}" ]
	then
		frobulator.err "Missing link source or target"
		echo

		return 1
	fi

	if [ "${#}" -lt 3 ]
	then
		frobulator.err "Missing link item"
		echo

		return 1
	fi

	# target directory

	if [ ! -d "${target}" ]
	then
		mkdir --parents "${target}"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	# link single item

	if [ "${#}" -eq 3 ]
	then
		item="${3}"
		link="${3}"

		if [ -e "${source}/${item}" ]
		then
			if [ -d "${source}/${item}" ]
			then
				type="directory"
			fi

			if [ -f "${source}/${item}" ]
			then
				type="file"
			fi

			frobulator.lnk "Linking ${type}" "[ ${link} ]"
			echo

			ln -s -f "${source}/${item}" "${target}/${link}"

			if [ "${?}" -ne 0 ]
			then
				status=1
			else
				frobulator.ownership "${target}/${link}"

				if [ "${?}" -ne 0 ]
				then
					status=1
				fi
			fi
		fi
	fi

	# link renamed item

	if [ "${#}" -eq 4 ]
	then
		item="${3}"
		link="${4}"

		if [ -e "${source}/${item}" ]
		then
			if [ -d "${source}/${item}" ]
			then
				type="directory"
			fi

			if [ -f "${source}/${item}" ]
			then
				type="file"
			fi

			frobulator.lnk "Linking ${type}" "[ ${link} ]"
			echo

			ln -s -f "${source}/${item}" "${target}/${link}"

			if [ "${?}" -ne 0 ]
			then
				status=1
			else
				frobulator.ownership "${target}/${link}"

				if [ "${?}" -ne 0 ]
				then
					status=1
				fi
			fi
		fi
	fi

	# link array

	if [ "${#}" -gt 4 ]
	then
		list=("${@:3}")

		for item in "${list[@]}"
		do
			link="${item}"

			if [ -e "${source}/${item}" ]
			then
				if [ -d "${source}/${item}" ]
				then
					type="directory"
				fi

				if [ -f "${source}/${item}" ]
				then
					type="file"
				fi

				frobulator.lnk "Linking ${type}" "[ ${link} ]"
				echo

				ln -s -f "${source}/${item}" "${target}/${link}"

				if [ "${?}" -ne 0 ]
				then
					status=1

					continue
				fi

				frobulator.ownership "${target}/${link}"

				if [ "${?}" -ne 0 ]
				then
					status=1
				fi
			fi
		done
	fi

	# unset array

	list=()

	return "${status}"

}

# image ////////////////////////////////////////////////////////////////////////

# use to display local or remote images directly in supported terminals
# supports local files, remote urls and stdin
# width defaults to terminal width
# preserves aspect ratio unless explicit height is specified

# image:
#              local image path
#              http/https image url

# width:
#              terminal cells or percentage
#              defaults to terminal width

# height:
#              terminal cells or percentage
#              disables automatic aspect ratio preservation

# usage:      frobulator.image "[image]"
#             frobulator.image "[image]" "[width]"
#             frobulator.image "[image]" "[width]" "[height]"

frobulator.image () {

	local status=0

	local image
	local width
	local height
	local ratio
	local input
	local encoding
	local inline
	local name
	local type
	local block
	local bytes
	local split
	local parts
	local part

	if [ "${#}" -eq 1 ]
	then
		image="${1}"

		width=${terminal_columns}

	elif [ "${#}" -eq 2 ]
	then
		image="${1}"
		width="${2}"

		ratio="1"

	elif [ "${#}" -eq 3 ]
	then
		image="${1}"
		width="${2}"
		height="${3}"

		ratio="0"
	fi

	if [ -z "${width}" ]
	then
		width=${terminal_columns}
	fi

	if [ -t 0 ]
	then
		# 'stdin' is a tty

		input="tty"
	else
		input="stdin"
	fi

	# verify image source:
	# url / local file

	if [[ "${image}" =~ ^(https?://)?[a-zA-Z0-9.-]+(\.[a-zA-Z]{2,})?(:[0-9]{1,5})?(/.*)?$ ]]
	then
		encoding="$(curl -s -L "${image}" | base64 -w 0)"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ -r "${image}" ]
	then
		encoding="$(cat "${image}" | base64 -w 0)"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	fi

	image_osc () {

		# osc - opening sequence characters
		# verify terminal multiplexer instance and type

		if [[ "${TERM}" == screen* || "${TERM}" == tmux* ]]
		then
			printf "\033Ptmux;\033\033]"
		else
			printf "\033]"
		fi
	}

	image_tsc () {

		# tsc - termination secquence characters
		# verify terminal multiplexer instance and type

		if [[ "${TERM}" == screen* ]] || \
		   [[ "${TERM}" == tmux*   ]]
		then
			printf "\a\033\\"
		else
			printf "\a"
		fi
	}

	image_parse () {

		# parameters

		image="${image}"

		input="${input}"

		encoding="${encoding}"

		inline="1"

		name="0"

		width="${width}"

		height="${height}"

		ratio="${ratio}"

		type=""

		block="1"

		echo

		# open sequence - begin transfer

		image_osc

		printf "1337;"

		if [[ "${block}" -eq 1 ]]
		then
			printf "File"
		else
			printf "MultipartFile"
		fi

		printf "=inline=%s" "${inline}"

		printf ";size=%d" "$(printf "%s" "${encoding}" | base64 -d -i | wc -c)"

		if [ -n "${image}" ]
		then
			printf ";name=%s" "$(printf "%s" "${image}" | base64 -w 0)"
		fi

		if [ -n "${width}" ]
		then
			printf ";width=%s" "${width}"
		fi

		if [ -n "${height}" ]
		then
			printf ";height=%s" "${height}"
		fi

		if [ -n "${ratio}" ]
		then
			printf ";preserveAspectRatio=%s" "${ratio}"
		fi

		#[ -n "${type}" ] && printf ";type=%s" "${type}"

		if [[ "${block}" -eq 1 ]]
		then
			printf ":%s" "${encoding}"

			image_tsc
		else
			image_tsc

			# split into 200-byte parts:
			# optimizes parsing through terminal multiplexer

			bytes=200

			split=$(fold -w ${bytes})

			parts=$(printf "%s" "${encoding}" | ${split})

			# load byte stream

			for part in "${parts}"
			do
				image_osc

				printf '1337;FilePart=%s' "${part}"

				image_tsc
			done

			# terminate sequence

			image_osc

			printf '1337;FileEnd'

			image_tsc
		fi

		echo

		if [ "${name}" = "1" ]
		then
			echo "Image: ${image}"
			echo
		fi
	}

	image_print () {

		if [ "${input}" = "stdin" ]
		then
			image=""
			inline="1"
			encoding=$(cat | base64 -w 0)

		elif [ "${input}" = "tty" ]
		then
			inline="1"
		fi

		image_parse "${image}" "${inline}" "${encoding}" "${name}" "${width}" "${height}" "${ratio}" "${type}" "${block}"
	}

	if [ -z "${image}" ]
	then
		frobulator.err "No image supplied"
		echo

		return 1
	fi

	image_print

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	return "${status}"

}

# http /////////////////////////////////////////////////////////////////////////

# use to validate http status code prior to download / upload operations
# use for url addresses [url] and data download validations [content]

# usage:      frobulator.http "[url]"				type: url		[default]

#             frobulator.http "[url]" "[content]"	type: content

frobulator.http () {

	local status=0

	local http_code="%{http_code}\n"
	local url="${1}"
	local data="${2}"

	if [ "${#}" -eq 1 ]
	then
		url_status="$(
			curl						\
				--silent				\
				--output "${sink}"		\
				--write-out "${http_code}"	\
				"${url}"
		)"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi

	elif [ "${#}" -eq 2 ]
	then
		url_status="$(
			curl							\
				--silent					\
				--output "${sink}"			\
				--write-out "${http_code}"		\
				--location					\
				"${url}/${data}"				\
			| tail -n 1					\
			| cut -d ':' -f 1
		)"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	else
		status=1
	fi

	return "${status}"

}

# status ///////////////////////////////////////////////////////////////////////

# use to parse and validate HTTP status responses and manage download actions
# use in tandem with frobulator.http

# usage:      frobulator.http "[url]"
#             frobulator.status

frobulator.status () {

	local status=0

	frobulator.fwd "Validating URL${marker_elp}"
	echo

	if [[ "${url_status}" = [1][0-9][0-9] ]]
	then
		url_status_label="information"

		frobulator.inf "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		proceed=1

	elif [[ "${url_status}" = [2][0-9][0-9] ]]
	then
		url_status_label="success"

		frobulator.scs "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		proceed=1

	elif [[ "${url_status}" = [3][0-9][0-9] ]]
	then
		url_status_label="redirect"

		frobulator.wrn "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		proceed=1

	elif [[ "${url_status}" = [4][0-9][0-9] ]]
	then
		url_status_label="error"

		frobulator.err "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		reason="client"

		proceed=0

		status=1

	elif [[ "${url_status}" = [5][0-9][0-9] ]]
	then
		url_status_label="error"

		frobulator.err "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		reason="server"

		proceed=0

		status=1
	else
		url_status_label="unknown"

		frobulator.err "Download status" "[ ${url_status_label}${marker_spc}${marker_hnt}${marker_spc}${url_status} ]"
		echo

		reason="response"

		proceed=0

		status=1
	fi

	return "${status}"

}

# download /////////////////////////////////////////////////////////////////////

# use to download file(s) with url status verification from argument or array list

# usage:      frobulator.download "[url]"                    "[directory]"             "[item]" | "[array]"
#             frobulator.download "[url]"/"[item]"           "[directory]"/"[item]"
#             frobulator.download "[url]"/"[source item]"    "[directory]"/"[item]"

frobulator.download () {

	local status=0

	local url="${1}"
	local path
	local file
	local source_file
	local data

	frobulator.http "${url}"

	if [ "${?}" -ne 0 ]
	then
		return 1
	fi

	frobulator.status

	if [[ "${proceed}" = 1 ]]
	then
		if [ "${#}" -eq 2 ]
		then
			path="${PWD}"

			if [[ "${#list[@]}" -gt 0 ]]
			then
				# ${2} - array

				list=("${@:2}")
			else
				file="${2}"

				list=()

				list+=("${file}")
			fi

		elif [ "${#}" -eq 3 ]
		then
			path="${2}"

			if [[ "${#list[@]}" -gt 0 ]]
			then
				# ${3} - array

				list=("${@:3}")
			else
				file="${3}"

				list=()

				list+=("${file}")
			fi

		elif [ "${#}" -eq 4 ]
		then
			source_file="${2}"
			path="${3}"

			if [ -z "${path}" ]
			then
				path="${PWD}"
			fi

			if [[ "${#list[@]}" -gt 0 ]]
			then
				# ${4} - array

				list=("${@:4}")
			else
				file="${4}"

				list=()

				list+=("${file}")
			fi
		else
			path="${2}"

			if [ -z "${path}" ]
			then
				path="${PWD}"
			fi

			if [[ "${#list[@]}" -gt 0 ]]
			then
				# ${3} - array

				list=("${@:3}")
			else
				file="${3}"

				list=()

				list+=("${file}")
			fi
		fi

		if [ ! -d "${path}" ]
		then
			mkdir --parents "${path}"

			if [ "${?}" -ne 0 ]
			then
				list=()

				unset proceed

				return 1
			fi
		fi

		for file in "${list[@]}"
		do
			if [ "${#}" -eq 4 ]
			then
				data="${source_file}"
			else
				data="${file}"
			fi

			frobulator.http "${url}" "${data}"

			if [ "${?}" -ne 0 ]
			then
				status=1

				continue
			fi

			frobulator.status

			if [[ "${proceed}" = 1 ]]
			then
				if [ "${#}" -eq 2 ]
				then
					curl			\
						--silent	\
						--location	\
									"${url}" > "${path}/${file}" &

				elif [ "${#}" -eq 3 ]
				then
					curl			\
						--silent	\
						--location	\
									"${url}/${file}" > "${path}/${file}" &

				elif [ "${#}" -eq 4 ]
				then
					curl			\
						--silent	\
						--location	\
									"${url}/${source_file}" > "${path}/${file}" &
				else
					curl			\
						--silent	\
						--location	\
									"${url}/${file}" > "${path}/${file}" &
				fi

				if [ "${?}" -ne 0 ]
				then
					status=1

					continue
				fi

				frobulator.progress "download" "[ '${file}' ]"

				if [ "${?}" -ne 0 ]
				then
					status=1

					continue
				fi

				# set permissions

				chmod a+rx "${path}/${file}"

				if [ "${?}" -ne 0 ]
				then
					status=1
				fi

			elif [[ "${proceed}" = 0 ]]
			then
				frobulator.stp "Skipping" "[ '${file}' ]"
				echo

				frobulator.wrn "File missing or unavailable."
				frobulator.nul "Review file spelling or availability for URL at:"
				frobulator.url "${marker_web}${url}"
				echo

				status=1
			else
				status=1
			fi
		done

		# unset array

		list=()

		unset proceed

		return "${status}"

	elif [[ "${proceed}" = 0 ]]
	then
		frobulator.err "Download error" "[ response${marker_hnt}${url_status} ]"
		frobulator.nul "Cannot continue - ${reason} unavailable."
		echo

		frobulator.stp "Aborting${marker_elp}"
		echo

		unset proceed

		return 1
	fi

	unset proceed

	return 1

}

# upload ///////////////////////////////////////////////////////////////////////

# use to upload data or file(s) with url from argument or array list

# usage:      frobulator.upload "[request]" "[url]" "[item]" | "[array]"

#             item as data or path to item prefixed with @
#             array as array of data or items

frobulator.upload () {

	local status=0

	local request="${1}"
	local url="${2}"
	local data
	local file
	local header
	local command_upload=()

	# validation

	if [ -z "${request}" ] || [ -z "${url}" ]
	then
		frobulator.err "Missing upload request or url"
		echo

		return 1
	fi

	if [ "${#}" -lt 3 ]
	then
		frobulator.err "No data provided for request" "[ ${request} ]" >&2
		echo

		return 1
	fi

	# set upload list

	if [[ "${#list[@]}" -gt 0 ]]
	then
		list=("${@:3}")
	else
		data="${3}"

		list=()

		list+=("${data}")
	fi

	# validate upload target

	frobulator.http "${url}"

	if [ "${?}" -ne 0 ]
	then
		list=()

		unset proceed

		return 1
	fi

	frobulator.status

	if [[ "${proceed}" = 0 ]]
	then
		frobulator.err "Upload error" "[ response${marker_hnt}${url_status} ]"
		frobulator.nul "Cannot continue - ${reason} unavailable."
		echo

		frobulator.stp "Aborting${marker_elp}"
		echo

		list=()

		unset proceed

		return 1
	fi

	if [[ "${proceed}" != 1 ]]
	then
		list=()

		unset proceed

		return 1
	fi

	# upload items

	for data in "${list[@]}"
	do
		command_upload=(
			curl
			--request "${request}"
		)

		if [ -z "${data}" ]
		then
			frobulator.err "No data provided for request" "[ ${request} ]" >&2
			echo

			status=1

			continue

		elif [[ "${data}" =~ ^\{.*\}$ ]]
		then
			# json data

			header="Content-Type: application/json"

			command_upload+=(
				--header "${header}"
				--data "${data}"
			)

		elif [[ "${data}" = @* ]]
		then
			# file / form data

			file="${data#@}"

			if [ ! -s "${file}" ]
			then
				frobulator.err "File is empty or does not exist" "[ ${file} ]" >&2
				echo

				status=1

				continue
			fi

			command_upload+=(
				--form "file=@${file}"
			)

		else
			# form data

			header="Content-Type: application/x-www-form-urlencoded"

			command_upload+=(
				--header "${header}"
				--data "${data}"
			)
		fi

		command_upload+=("${url}")

		"${command_upload[@]}"

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	done

	# unset array

	list=()

	unset proceed

	return "${status}"

}

# silence //////////////////////////////////////////////////////////////////////

# use to wrap command execution and redirect all output to null sink
# provides fully silent execution

# usage:      frobulator.silence "[command]"

frobulator.silence () {

	local status=0

	local command="${*}"

	"${SHELL}" -c "${command}" >> "${sink}" 2>&1

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	return "${status}"

}

# log //////////////////////////////////////////////////////////////////////////

# use to wrap command and redirect all output to "${script}"-"${stamp}".log file
# provides fully silent execution

# usage:      frobulator.log "[command]"

frobulator.log () {

	local status=0

	local command="${*}"
	local log_directory
	local log

	if [ -z "${SUDO:-${HOME}}" ]
	then
		log_directory="${PREFIX}/var/log"
	else
		if [ ! -d "${HOME}/.local/var/log" ]
		then
			mkdir --parents "${HOME}/.local/var/log"

			if [ "${?}" -ne 0 ]
			then
				return 1
			fi
		fi

		log_directory="${HOME}/.local/var/log"
	fi

	if [ -z "${script}" ]
	then
		script="$(basename -- "${BASH_SOURCE[0]}")"

		if [ "${?}" -ne 0 ]
		then
			return 1
		fi
	fi

	script="${script##*/}"

	log="${log_directory}/${script}-${stamp}.log"

	"${SHELL}" -c "${command}" >> "${log}" 2>&1

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	return "${status}"

}

# password /////////////////////////////////////////////////////////////////////

# use to obfuscate password input with custom mask character

# usage:      frobulator.password

frobulator.password () {

	local status=0

	local mask_character="•"
	local input_character
	local mask=""

	password=""

	while read -p "${mask}" -r -s -n 1 input_character
	do
		# enter / accept password

		if [[ "${input_character}" == $'\0' ]]
		then
			# break on 'NUL'

			break
		fi

		# handle backspace / delete character input

		if [[ "${input_character}" == $'\177' ]]
		then
			# remove input on 'BACKSPACE'/'DEL'

			if [ -n "${password}" ]
			then
				mask=$'\b \b'

				password="${password%?}"
			else
				mask=""
			fi
		else
			# set character mask

			mask="${mask_character}"

			# append user input and form password

			password+="${input_character}"
		fi
	done

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	input="${password}"

	# normalize line spacing:
	# additional 'echo' required due to 'read'

	echo

	return "${status}"

	}

# input ////////////////////////////////////////////////////////////////////////

# use to capture user input

# usage:      frobulator.input "[array]"

frobulator.input () {

	local status=0

	local prompt
	local label
	local input

	list=("${@}")

	for prompt in "${list[@]}"
	do
		label="${prompt^}"
		prompt="$(echo "${label}" | sed 's/_/ /'):"

		frobulator.ipt "${prompt}"

		if [[ "${prompt}" = *password* ]]
		then
			frobulator.password

			if [ "${?}" -ne 0 ]
			then
				status=1

				continue
			fi

			input="${password}"
		else
			read -r input

			if [ "${?}" -ne 0 ]
			then
				status=1

				continue
			fi
		fi

		# prevent empty input

		while true
		do
			if [ -z "${input}" ]
			then
				echo
				frobulator.err "${prompt%:} cannot be empty"
				echo

				prompt="$(echo "${label}" | sed 's/_/ /'):"

				frobulator.ipt "${prompt}"

				if [[ "${prompt}" = *password* ]]
				then
					frobulator.password

					if [ "${?}" -ne 0 ]
					then
						status=1

						break
					fi

					input="${password}"
				else
					read -r input

					if [ "${?}" -ne 0 ]
					then
						status=1

						break
					fi
				fi
			else
				break
			fi
		done

		label="${label,}"

		frobulator_return+=("${label}=${input}")
	done

	# unset array

	list=()

	# normalize line spacing:
	# additional 'echo' required due to 'read'

	echo

	return "${status}"

}

# clean ////////////////////////////////////////////////////////////////////////

# use to run package and installer post-install cleanup

# usage:      frobulator.clean

# clean ////////////////////////////////////////////////////////////////////////

frobulator.clean () {

	local status=0

	local command_autoremove="apt-get autoremove"
	local command_autoclean="apt-get autoclean"
	local command_clean="apt-get clean"

	frobulator.log "${command_autoremove}" &

	frobulator.process "Flushing package(s)"

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	frobulator.log "${command_autoclean}" &

	frobulator.progress "Autoclean"

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	frobulator.log "${command_clean}" &

	frobulator.progress "Clean"

	if [ "${?}" -ne 0 ]
	then
		status=1
	fi

	# fix dpkg lock and errors
	# remove post-install logs to prevent package configuration errors

	if [ -d "${PREFIX}"/var/lib/dpkg/info ]
	then
		rm																\
			--recursive													\
			--force			"${PREFIX}"/var/lib/dpkg/info/*.postinst	\
																		>> "${sink}" 2>&1

		if [ "${?}" -ne 0 ]
		then
			status=1
		fi
	fi

	return "${status}"

}

